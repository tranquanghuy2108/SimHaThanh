@using Commons.Enums;
@model Models.Requests.SearchSIMRequest
@{
    bool IsMobile = ViewBag.IsMobile;
    ViewData["Title"] = "Tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<input type="hidden" value="@ViewBag.SearchType" id="SearchType" />
<input type="hidden" value="@ViewBag.slug" id="slug" />
<input type="hidden" value="@IsMobile" id="IsMobile" />

@if (!IsMobile)
{
    <div class="block mt-15">
        <div class="block-head">Tìm sim số đẹp</div>
        <div class="block-body p-3">
            <div class="hidden" id="simdata">
                <div class="sim-table--body col-12 px-0">
                    <table id="myTable" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th style="width:25%">Số điện thoại</th>
                                <th style="width:20%">Giá</th>
                                <th style="width:18%">Nhà mạng</th>
                                <th style="width:18%">Loại SIM</th>
                                <th style="width:17%">Đặt mua</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </div>
                <div id="paging" class="px-3">
                    <nav aria-label="Page navigation example">
                        <ul class="pagination pagination-md">
                        </ul>
                    </nav>
                </div>
            </div>

            <div class="hidden" id="simnotfound">
                <p class="align-middle mb-0">Sim bạn tìm hiện vẫn chưa được cập nhật lên web</p>
                <p class="align-middle mb-0">
                    Quý khách có nhu cầu sử dụng số này, hãy liên hệ với chúng tôi để được hỗ trợ nhanh nhất!
                </p>
                <div class="mt-3 mb-0 d-flex flex-wrap justify-content-center">
                    <br>
                    <div class="support-btn support-btn--zalo d-inline mx-2">
                        <a target="_blank" href="//zalo.me/" class="color-white">
                            <img class="support-icon--img nt-rotate" src="/assets/img/zalo-icon.png" alt="">
                            <span>Chat Zalo</span>
                        </a>
                    </div>
                    <div class="support-btn support-btn--fb d-inline mx-2">
                        <a target="_blank" href="//m.me/0911.92.9999" class="color-white">
                            <img class="support-icon--img nt-rotate" src="~/assets/img/messenger-icon.png" alt="">
                            <span>Chat Facebook</span>
                        </a>
                    </div>
                    <div class="support-btn d-inline mx-2">
                        <a target="_blank" href="tel:0911.92.9999">
                            <img class="support-icon--img nt-rotate" src="~/assets/img/tel-icon.png" alt="">
                            <span>0911.92.9999</span>
                        </a>
                    </div>

                </div>
            </div>

        </div>
    </div>
}
else
{
    <h4 class="text-center m-2"><strong>TÌM KIẾM SIM</strong></h4>
    <div class="block mt-15">
        <div class="block-head">KẾT QUẢ</div>
        <div class="block-body pt-3 px-0 pb-0">
            <div class="sim-table--body col-12 px-0">
                <div class="sim-table--wrap">
                    <div class="row" id="datamobileresult">
                    </div>
                    <div class="col-12 p-3 m3 text-center" id="datamobilenextpage">
                    </div>
                    <div class="hidden" id="simnotfound">
                        <p class="align-middle mb-0">Sim dạng hiện vẫn chưa được cập nhật lên web</p>
                        <p class="align-middle mb-0">
                            Quý khách có nhu cầu sử dụng số dạng này, hãy liên hệ với chúng tôi để được hỗ trợ nhanh nhất!
                        </p>
                        <div class="mt-3 mb-0 d-flex flex-wrap justify-content-center">
                            <br>
                            <div class="support-btn support-btn--zalo d-inline mx-2">
                                <a target="_blank" href="//zalo.me/" class="color-white">
                                    <img class="support-icon--img nt-rotate" src="/assets/img/zalo-icon.png" alt="">
                                    <span>Chat Zalo</span>
                                </a>
                            </div>
                            <div class="support-btn support-btn--fb d-inline mx-2">
                                <a target="_blank" href="//m.me/0911.92.9999" class="color-white">
                                    <img class="support-icon--img nt-rotate" src="~/assets/img/messenger-icon.png" alt="">
                                    <span>Chat Facebook</span>
                                </a>
                            </div>
                            <div class="support-btn d-inline mx-2">
                                <a target="_blank" href="tel:0911.92.9999">
                                    <img class="support-icon--img nt-rotate" src="~/assets/img/tel-icon.png" alt="">
                                    <span>0911.92.9999</span>
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
<script>
    window.onload = function () {
        // var itemNav = document.getElementById("phong-thuy");
        // itemNav.classList.add("active");
        // var fengshuiAbout = document.getElementById("fengshui-about");
        // fengshuiAbout.classList.remove("hidden");
        SearchSim(1);
    };
    function SearchSim(pageIndex) {
        var searchType = $("#SearchType").val();
        var keyword = $("#slug").val();
        var dataReq = {
            "keyword": keyword,
            "searchType": parseFloat(searchType),
            "pageIndex": pageIndex,
            "pageSize": 50
        }
        $.ajax({
            url: '@Url.Action("TimSim","Home")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(dataReq),
            xhrFields: {
                withCredentials: true // Gửi kèm cookie (nếu bạn đang dùng cookie auth)
            },
            success: function (data) {
                window.scrollTo(0, 0);
                if (data != undefined) {
                    if (data.data.length > 0) {
                        var isMobile = @IsMobile.ToString().ToLower();
                        if (!isMobile) {
                            var simdata = document.getElementById("simdata");
                            simdata.classList.remove("hidden");

                            //Write table tbody
                            var tbody = $("#myTable tbody")
                            tbody.children().remove();
                            var newBody = "";
                            data.data.forEach((el) => {
                                newBody += '<tr id="sim'+el.id+'">'
                                    + '<td>'
                                    + '<a href="javascript:void(0)" onclick="AddSimToCart('+el.id+', \''+el.simNumber+'\', '+el.simPrice+')">'
                                    + '<span class="tb-sim-num">' + el.simNumber + '</span>'
                                    + '</a>'
                                    + '</td>'
                                    + '<td><span class="tb-sim-price">' + formatNumber(el.simPrice.toString()) + ' đ</span></td>'
                                    + '<td><span class="tb-sim-network">' + el.network + '</span></td>'
                                    + '<td><span class="tb-sim-type">' + (el.simType ? el.simType : "") + '</span></td>'
                                    + '<td class="table-action">'
                                    + '<a class="btn btn-warning" href="javascript:void(0)" onclick="AddSimToCart('+el.id+', \''+el.simNumber+'\', '+el.simPrice+')" style="font-size: 12px;"><i class="bi bi-cart-plus"></i></a>'
                                    + '</td>'
                                    + '</tr>';
                            });
                            tbody.append(newBody);
                            //write paging
                            var paging = $("#paging .pagination")
                            paging.children().remove();
                            var pagingItem = "";
                            if (data.pager.totalPages > 0) {
                                if (data.pager.currentPage > 1) {
                                    pagingItem += '<li class="page-item" ><a class="page-link" onclick="SearchSim(1)" >Trang đầu</a></li>'
                                };
                                for (var pge = data.pager.startPage; pge <= data.pager.endPage; pge++) {
                                    if (pge == data.pager.currentPage)
                                        pagingItem += '<li class="page-item active"><a class="page-link" onclick="SearchSim(' + pge + ')" >' + pge + '</a></li>'
                                    else
                                        pagingItem += '<li class="page-item "><a class="page-link" onclick="SearchSim(' + pge + ')" >' + pge + '</a></li>'
                                }
                                if (data.pager.currentPage < data.pager.totalPages) {
                                    pagingItem += '<li class="page-item" ><a class="page-link" onclick="SearchSim(' + data.pager.totalPages + ')" >Trang cuối</a></li>'
                                };
                            }
                            paging.append(pagingItem);
                        }
                        else {
                            var tbody = $("#datamobileresult")
                            tbody.children().remove();
                            var newBody = "";


                            data.data.forEach((el) => {
                                var imgSrc = "";

                                switch (el.network.toLowerCase()) {
                                    case "viettel":
                                        imgSrc = "/assets/img/network/sim-vietel.png";
                                        break;
                                    case "vinaphone":
                                        imgSrc = "/assets/img/network/sim-vina.png";
                                        break;
                                    case "mobiphone":
                                        imgSrc = "/assets/img/network/sim-mobi.png";
                                        break;
                                    case "vietnamobile":
                                        imgSrc = "/assets/img/network/sim-vina.png";
                                        break;
                                    case "gmobile":
                                        imgSrc = "/assets/img/network/sim-gmobile.png";
                                        break;
                                    case "itelecom":
                                        imgSrc = "/assets/img/network/sim-itel.png";
                                        break;
                                }
                                newBody += '<div class="col-6 col-xl-4 pl-0 item-result" id="sim'+el.id+'">'
                                    + '<div class="container sim-item sim-hot">'
                                    + '<a href="#" onclick="AddSimToCard(' + el.id + ',' + el.simNumber + el.simPrice + ');" >'
                                    + '<div class="row">'
                                    + '<div class="col-4" style="max-width: 55px;">'
                                    + '<img class="lazy" src="' + imgSrc + '" style="width: 50px;height: auto;padding-top: 5px;" />'
                                    + '</div>'
                                    + '<div class="col-8"  style="max-width: 130px;">'
                                    + '<span class="sim-item--number">' + el.simNumber + '</span><br>'
                                    + '<span class="sim-item--price">' + formatNumber(el.simPrice.toString()) + 'đ</span>'
                                    + '</div>'
                                    + '</div>'
                                    + '</a>'
                                    + '</div>'
                                    + '</div>';
                            });
                            tbody.append(newBody);

                            //datamobilenextpage
                            //<button class="btn btn-danger" onclick = "ShowMore()" id = "showmore" > Xem thêm ...</button>
                            var paging = $("#datamobilenextpage")
                            paging.children().remove();
                            var pagingItem = "";
                            if (data.pager.totalPages > 0) {
                                if (pageIndex < data.pager.totalPages) {
                                    pagingItem += '<button class="btn btn-danger" onclick = "SearchSim(' + (pageIndex + 1) + ')" id = "showmore" > Xem thêm ...</button>'
                                };
                            }
                            paging.append(pagingItem);
                        }
                    }
                    else {
                        var simnotfound = document.getElementById("simnotfound");
                        simnotfound.classList.remove("hidden");
                    }
                }
            },
            error: function (xhr) {
                console.log(xhr);
            }
        });
    }
</script>
