@model Models.ViewModels.SIMOrderModel
@{
    var IsMobile = ViewBag.IsMobile;
    ViewData["Title"] = "Đặt Sim Data";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="block row border-radius-3">
    <form method="post" id="ordered" action="" class="form" onsubmit="return OrderSim();">
        <div class="block-body p-3">
            <h2 class="block-title text-center">@ViewBag.SimInfo.Name</h2>
            <input type="hidden" id="ProductTypeId" value="@ViewBag.SimInfo.Id" />
            <input type="hidden" id="simIds" value="@ViewBag.SimIds" />
            <div class="box-order mt-15">
                <div class="row">
                    <div class="col-12">
                        @Html.Raw(@ViewBag.SimInfo.Description)
