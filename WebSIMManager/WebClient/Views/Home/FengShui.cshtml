<div class="sidebar " style="background:white;">
    <div class="sidebar-item px-3">
        <div class="col-8 mb-3">
            <label for="exampleInputEmail1" class="form-label">Sim muốn xem</label>
            <input id="simNumber" type="text" class="form-control">
        </div>
        <div class="">
            <div class="row">
                <div class="col-7">
                    <div class="row">
                        <div class="col-4">
                            <label class="form-label">Ngày sinh</label>
                            <select class="form-select pr-3" id="dateOfBirth">
                                @for (int i = 1; i <= 31; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label">Tháng sinh</label>
                            <select class="form-select pr-3" id="monthOfBirth">
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                        <div class="col-4">
                            <label class="form-label">Năm sinh</label>
                            <select class="form-select pr-3" id="yearOfBirth">
                                @for (int i = 1925; i <= 2018; i++)
                                {
                                    <option value="@i">@i</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-3">
                    <label class="form-label">Giờ sinh</label>
                    <select class="form-select pr-3" id="giosinh">
                        <option selected="selected" value="1">Tý (23-12h)</option>
                        <option value="2">Sửu (1h-3h)</option>
                        <option value="3">Dần (3h-5h)</option>
                        <option value="4">Mão (5h-7h)</option>
                        <option value="5">Thìn (7h-9h)</option>
                        <option value="6">Tỵ (9h-11h)</option>
                        <option value="7">Ngọ (11h-13h)</option>
                        <option value="8">Mùi (13h-15h)</option>
                        <option value="9">Thân (15h-17h)</option>
                        <option value="10">Dậu (17h-19h)</option>
                        <option value="11">Tuất (19h-21h)</option>
                        <option value="12">Hợi (21h-23h)</option>
                    </select>
                </div>
                <div class="col-2">
                    <label class="form-label">Giới tính</label>
                    <select class="form-select pr-3" id="giosinh">
                        <option selected="selected" value="1">Nam</option>
                        <option value="0">Nữ</option>
                    </select>
                </div>
            </div>

            <div class="mt-5 position-relative text-center">
                <button type="button" class="btn btn-danger" width="300px" onclick="CheckSimPT();">Xem điểm phong thủy</button>
            </div>
        </div>
    </div><!-- End sidebar search formn-->
</div>

