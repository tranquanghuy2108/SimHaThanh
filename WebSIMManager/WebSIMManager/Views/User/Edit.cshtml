@using Models.ViewModels
@model UserEditRequest
@{
	ViewData["Title"] = "Chỉnh sửa người dùng";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Chỉnh sửa người dùng</h1>

<div class="col-12">
	<div class="card">
		<div class="card-body">
			<form method="post">
				<div class="form-group col-md-6">
					<label class="form-label required">Tên đầy đủ</label>
					<input type="text" class="form-control" placeholder="Tên đầy đủ" asp-for="FullName">
					<input type="hidden" asp-for="IsAgent" value="false">
					@Html.HiddenFor(model =>model.Id)
				</div>
				<div class="form-group col-md-6">
					<label class="form-label required">Tên đăng nhập</label>
					<input type="text" class="form-control" placeholder="Tên đăng nhập" asp-for="Username" readonly>
				</div>
				<div class="form-group col-md-6">
					<label class="form-label required">Email address</label>
					<input type="email" class="form-control" placeholder="Email" asp-for="Email">
				</div>
				<div class="form-group col-md-6">
					<label class="form-label required">Số điện thoại</label>
					<input type="text" class="form-control" placeholder="Số điện thoại" asp-for="PhoneNumber">
				</div>
				<div class="form-group col-md-6">
					<label class="form-label required">Địa chỉ</label>
					<input type="text" class="form-control" placeholder="Địa chỉ" asp-for="Address">
				</div>
				<div class="form-group col-md-6">
					<label class="form-label required">Quyền</label>
					<select class="form-control mb-3" asp-for="GroupId" asp-items="@ViewBag.GroupLst" data-live-search="true">
					</select>
				</div>
				<div asp-validation-summary="All" class="text-danger"></div>
				<button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Edit" asp-controller="User" width="100px">Cập nhật</button>
				<button type="submit" class="btn btn-secondary m-3 btn-default" asp-action="Index" asp-controller="User" width="100px">Trở về</button>
			</form>
		</div>
	</div>
</div>

<script>
	$(function () {
		$('#SettingsCollapse').removeClass("collapsed");
		$('#settings').addClass("show");
		$('#UserLst').addClass("active");
	});
</script>