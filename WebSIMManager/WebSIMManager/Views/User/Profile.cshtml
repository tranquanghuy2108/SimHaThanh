@using Models.ViewModels
@model UserEditRequest
@{
    ViewData["Title"] = "Hồ sơ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid p-0">

    <h1 class="h3 mb-3">Hồ sơ người dùng</h1>

    <div class="row">
        <div class="col-md-3 col-xl-2">

            <div class="card">
                <div class="list-group list-group-flush">
                    <a class="list-group-item active" asp-action="Profile" asp-controller="User">
                        Thông tin tài khoản
                    </a>
                    <a class="list-group-item" asp-action="ChangePassword" asp-controller="User">
                        Mật khẩu
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-9 col-xl-10">
            <div class="tab-content">
                <div class="tab-pane fade show active" id="account" role="tabpanel">

                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">Cập nhật thông tin</h5>
                        </div>
                        <div class="card-body">
                            <form method="post">
                                <div class="form-group col-md-6">
                                    <label class="form-label required">Tên đầy đủ</label>
                                    <input type="text" class="form-control" placeholder="Tên đầy đủ" asp-for="FullName">
                                    @Html.HiddenFor(model =>model.Id)
                                </div>
                                <div class="form-group col-md-6">
                                    <label class="form-label required">Tên đăng nhập</label>
                                    <input type="text" class="form-control" placeholder="Tên đăng nhập" asp-for="Username" disabled>
                                </div>
                                <div class="form-group col-md-6">
                                    <label class="form-label required">Email address</label>
                                    <input type="email" class="form-control" placeholder="Email" asp-for="Email" disabled>
                                </div>
                                <div class="form-group col-md-6">
                                    <label class="form-label required">Số điện thoại</label>
                                    <input type="text" class="form-control" placeholder="Số điện thoại" asp-for="PhoneNumber">
                                </div>
                                <div class="form-group col-md-6">
                                    <label class="form-label required">Quyền</label>
                                    <select class="form-control mb-3" asp-for="GroupId" asp-items="@ViewBag.RoleLst" disabled>
                                    </select>
                                    @Html.HiddenFor(model =>model.GroupId)
                                </div>
                                <div asp-validation-summary="All" class="text-danger"></div>
                                <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Profile" asp-controller="User" width="100px">Cập nhật</button>
                            </form>

                        </div>
                    </div>

                </div>

            </div>
        </div>
    </div>

</div>

