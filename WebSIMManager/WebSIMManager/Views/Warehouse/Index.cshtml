@using Commons.Enums;
@model Models.Requests.GetPagingRequest
@using System.Security.Claims;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.User.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray();
    ViewData["Title"] = "Kênh bán hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Quản lý kênh bán hàng</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="row">
                    <div class="col-sm-6 text-left">
                        @if (role.Contains("Tạo mới kênh bán hàng"))
                        {
                            <a class="btn btn-primary" asp-action="Create" asp-controller="SPContact">Thêm kênh bán hàng</a>
                        }
                    </div>
                    <div class="col-sm-6 text-right">
                        <form class="form-inline d-none d-sm-inline-block">
                            <div class="input-group input-group-navbar">
                                <input type="text" asp-for="keyword" class="form-control" placeholder="Số hỗ trợ..." aria-label="Search">
                                <div class="input-group-append">
                                    <button class="btn" type="submit" asp-action="Index" asp-controller="SPContact">
                                        <i class="align-middle" data-feather="search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-3">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th style="width:10%;">#</th>
                        <th style="width:20%">Số điện thoại</th>
                        <th style="width:20%">Loại liên lạc</th>
                        <th style="width:40%">Ghi chú</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        foreach (var item in @ViewBag.DataView)
                        {
                            <tr>
                                <td>@item.stt</td>
                                <td>@item.PhoneNumber</td>
                                <td>@Enum.GetName(typeof(SupportContactType), item.SupportContactType)</td>
                                <td>@item.Remark</td>
                                <td class="table-action">

                                    @if (role.Contains("Sửa kênh bán hàng"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" title="Sửa kênh bán hàng"><i class="align-middle" data-feather="edit-2"></i></a>
                                    }
                                    @if (role.Contains("Xóa kênh bán hàng"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" title="Xóa kênh bán hàng"><i class="align-middle" data-feather="trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#SettingsCollapse').removeClass("collapsed");
        $('#settings').addClass("show");
        $('#contactLst').addClass("active");
    });
</script>