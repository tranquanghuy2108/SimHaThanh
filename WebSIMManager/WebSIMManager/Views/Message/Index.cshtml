<script>
    $(function () {
        OnLoadMyGroupChannel();
    });
    function OnLoadMyGroupChannel() {
        Onloading();
        $.ajax({
            url: '@Url.Action("GetGroupChannel", "Message")',
            type: "GET",
            contentType: "application/json",
            success: function (data) {
                OnloadingSuccess();
                //Show group channel
                var myGroupChannel = $("#myGroupChannel")
                myGroupChannel.children().remove();
                var group_channels = "";
                data.channels.forEach((el) => {
                    var last_mess = el.last_message.message;
                    if (last_mess.length > 15) last_mess = last_mess.substring(0, 15) + '...';
                    var unread_message_count = el.unread_message_count;
                    var unreadMess = '';
                    if (el.unread_message_count > 0) unreadMess = '<div class="badge bg-success float-right">' + el.unread_message_count + '</div>'
                    group_channels += '<a onclick="OnClickGroupChannel(' + "'" + el.channel_url + "','" + el.inviter.nickname + "'" + ')" class="list-group-item list-group-item-action border-0">'
                        + unreadMess
                        + '<div class="d-flex align-items-start">'
                        + '<img src="' + (el.inviter.profile_url == "" ? "https://bootdey.com/img/Content/avatar/avatar6.png" : el.inviter.profile_url) + '" class="rounded-circle mr-1" alt="Vanessa Tucker" width="40" height="40">'
                        + '<div class="flex-grow-1 ml-3">'
                        + '<strong>' + el.inviter.nickname + '</strong>'
                        + '<div class="small">' + last_mess + '</div>'
                        + '</div>'
                        + '</div>'
                        + '</a>';
                });
                myGroupChannel.append(group_channels);
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    }
    function OnClickGroupChannel(channel_url, chat_user) {
        $('#channel_url').val(channel_url);
        $('#chat_user').text(chat_user);
        //Onloading();
        //Đánh dấu tin đã đọc
        $.ajax({
            url: '@Url.Action("MaskReadMessage", "Message")?channel_url=' + channel_url,
            type: "GET",
            contentType: "application/json",
            success: function (data) {
                //OnloadingSuccess();
                //Show group channel
                OnLoadMyGroupChannel();
                OnLoadListMessageOnChannel();
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    }
    function OnLoadListMessageOnChannel() {
        var channel_url = $('#channel_url').val();
        //Onloading();
        $.ajax({
            url: '@Url.Action("GetListMessage", "Message")?channel_url=' + channel_url,
            type: "GET",
            contentType: "application/json",
            success: function (data) {
                //OnloadingSuccess();
                //Show group channel
                var chatHistory = $("#chat_history")
                var userId = $('#user_id').val();
                chatHistory.children().remove();
                var chat_message = "";
                data.messages.forEach((el) => {
                    var create_at = new Date(el.created_at);
                    if (el.user.user_id != userId) {
                        chat_message += '<div class="chat-message-left pb-4">'
                            + '<div>'
                            + '<img src="https://bootdey.com/img/Content/avatar/avatar6.png" class="rounded-circle mr-1" alt="Sharon Lessman" width="40" height="40">'
                            + '<div class="text-muted small text-nowrap mt-2">' + formatAMPM(create_at) + '</div>'
                            + '</div>'
                            + '<div class="flex-shrink-1 bg-light rounded py-2 px-3 ml-3">'
                            //+ '<div class="font-weight-bold mb-1">' + el.user.nickname+ '</div>'
                            + el.message
                            + '</div>'
                            + '</div>';
                    }
                    else {
                        chat_message += '<div class="chat-message-right pb-4">'
                            + '<div>'
                            + '<img src="https://bootdey.com/img/Content/avatar/avatar7.png" class="rounded-circle mr-1" alt="Chris Wood" width="40" height="40">'
                            + '<div class="text-muted small text-nowrap mt-2">' + formatAMPM(create_at) + '</div>'
                            + '</div>'
                            + '<div class="flex-shrink-1 bg-light rounded py-2 px-3 mr-3">'
                            + '<div class="font-weight-bold mb-1">You</div>'
                            + el.message
                            + '</div>'
                            + '</div>';
                    }
                });
                chatHistory.append(chat_message);
                var elem = document.getElementById('chat_history');
                elem.scrollTop = elem.scrollHeight;
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    } 
    function formatAMPM(date) {
        var hours = date.getHours();
        var minutes = date.getMinutes();
        var ampm = hours >= 12 ? 'pm' : 'am';
        hours = hours % 12;
        hours = hours ? hours : 12; // the hour '0' should be '12'
        minutes = minutes < 10 ? '0' + minutes : minutes;
        var strTime = hours + ':' + minutes + ' ' + ampm;
        return strTime;
    }
    function OnSendMessage() {
        var channel_url = $('#channel_url').val();
        var message = $('#message').val();
        //Onloading();
        $.ajax({
            url: '@Url.Action("SendMessage", "Message")?channel_url=' + channel_url + '&message=' + message,
            type: "GET",
            contentType: "application/json",
            success: function (data) {
                //OnloadingSuccess();
                //Show group channel
                OnLoadListMessageOnChannel();
                $('#message').val('');
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    }
</script>