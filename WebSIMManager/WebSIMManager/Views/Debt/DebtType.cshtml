@model Models.Requests.GetPagingRequest
@using System.Security.Claims;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.User.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray();
    ViewData["Title"] = "Loại công nợ phát sinh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Loại công nợ phát sinh</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="row">
                    <div class="col-sm-6 text-left">
                        @if (role.Contains("Tạo mới loại công nợ"))
                        {
                            <a class="btn btn-primary" asp-action="CreateDebtType" asp-controller="Debt">Thêm loại công nợ</a>
                        }
                    </div>
                    <div class="col-sm-6 text-right">
                        <form class="form-inline d-none d-sm-inline-block">
                            <div class="input-group input-group-navbar">
                                <input type="text" asp-for="keyword" class="form-control" placeholder="Nhập từ khóa..." aria-label="Search">
                                <div class="input-group-append">
                                    <button class="btn" type="submit" asp-action="DebtType" asp-controller="Debt">
                                        <i class="align-middle" data-feather="search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-3">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th style="width:5%;">Stt</th>
                        <th style="width:15%">Code</th>
                        <th style="width:20%">Tên loại công nợ</th>
                        <th style="width:20%">Hình thức loại công nợ</th>
                        <th class="d-none d-md-table-cell" style="width:30%">Mô tả</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        foreach (var item in @ViewBag.DataView)
                        {
                            <tr>
                                <td>@item.Stt</td>
                                <td>@item.Code</td>
                                <td>@item.Name</td>
                                <td>@item.DebtReceiveType</td>
                                <td class="d-none d-md-table-cell">@item.Description</td>
                                <td class="table-action">
                                    @if (role.Contains("Sửa loại công nợ"))
                                    {
                                        <a asp-action="EditDebtType" asp-route-id="@item.Id" title="Sửa loại công nợ"><i class="align-middle" data-feather="edit-2"></i></a>
                                    }
                                    @if (role.Contains("Xóa loại công nợ"))
                                    {
                                        <a asp-action="DeleteDebtType" asp-route-id="@item.Id" title="Xóa loại công nợ"><i class="align-middle" data-feather="trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div id="paging" class="px-3">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-md">
                    @if (ViewBag.Pager.TotalPages > 0)
                    {
                        @if (ViewBag.Pager.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="DebtType"
                                   asp-route-pageIndex="1"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">
                                    Trang đầu
                                </a>
                            </li>
                        }
                        @for (var pge = ViewBag.Pager.StartPage; pge <= ViewBag.Pager.EndPage; pge++)
                        {
                            <li class="page-item @(pge == ViewBag.Pager.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="DebtType"
                                   asp-route-pageIndex="@pge"
                                   asp-route-pageIndex="@ViewBag.Pager.TotalPages"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">@pge</a>
                            </li>
                        }
                        @if (ViewBag.Pager.CurrentPage < ViewBag.Pager.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="DebtType"
                                   asp-route-pageIndex="@ViewBag.Pager.TotalPages"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">
                                    Trang cuối
                                </a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#DebtCollapse').removeClass("collapsed");
        $('#debt').addClass("show");
        $('#debtType').addClass("active");
    });
</script>