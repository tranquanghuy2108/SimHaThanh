@using Models.ViewModels
@model DebtModels
@{
    ViewData["Title"] = "Tạo công nợ phát sinh";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Tạo công nợ phát sinh</h1>

<div class="col-12">
    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <form method="post">
                        <div class="form-group">
                            <label class="form-label">Loại phiếu phát sinh công nợ</label>
                            <div class="col-12 p-0">
                                <select asp-for="DebtTypeId" asp-items="@ViewBag.DebtTypes" type="text" data-live-search="true" onchange=" OnChangeDebtType(this);">
                                </select>
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">KH/Đại lý</label>
                            <div class="col-12 p-0">
                                <select asp-for="AgentId" asp-items="@ViewBag.Agents" type="text" data-live-search="true">
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <div class="form-group col-md-6" id="psThu">
                                <label class="form-label required">Phát sinh thu</label>
                                <input type="text" class="form-control currency" data-type="currency" asp-for="Receivables" />
                            </div>
                            <div class="form-group col-md-6" id="psChi">
                                <label class="form-label required">Phát sinh chi</label>
                                <input type="text" class="form-control currency" data-type="currency" asp-for="Liabilities" />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Ghi chú</label>
                            <textarea class="form-control" rows="2" placeholder="Yêu cầu khác" asp-for="Description"></textarea>
                        </div>

                        <div asp-validation-summary="All" class="text-danger"></div>
                        <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Create" asp-controller="Debt" width="100px">Tạo công nợ</button>
                        <button type="submit" class="btn btn-secondary m-3 btn-default" asp-action="Index" asp-controller="Debt" width="100px">Trở về</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    $(function () {
        $('#DebtCollapse').removeClass("collapsed");
        $('#debt').addClass("show");
        $('#debtLst').addClass("active");
        fomatCurrencyInput();
        OnChangeDebtType(document.getElementById('DebtTypeId'));
    });
    function OnChangeDebtType(sel) {
        var psThu = document.getElementById('psThu');
        var psChi = document.getElementById('psChi');
        psThu.classList.add("hidden");
        psChi.classList.add("hidden");
        if (sel.options[sel.selectedIndex].text.includes("(T)"))
            psThu.classList.remove("hidden");
        else if (sel.options[sel.selectedIndex].text.includes("(C)"))
            psChi.classList.remove("hidden");
        else {
            psThu.classList.remove("hidden");
            psChi.classList.remove("hidden");
        }
    }
</script>