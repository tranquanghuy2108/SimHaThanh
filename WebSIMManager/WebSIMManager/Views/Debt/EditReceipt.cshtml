                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div asp-validation-summary="All" class="text-danger"></div>
                <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="EditReceipt" asp-controller="Debt" width="100px">Sửa phiếu thu/chi</button>
