											</div>
										</div>
									</div>
								</div>
							</div>
							<!--Sim info-->

                            <div class="card-body px-3 row">
                                <div class="col-md-8">
                                    <div class="row">
                                        <div class="form-group col-md-4">
                                            <label class="form-label">Loại phiếu</label>
                                            <select class="form-control" asp-for="typeOfReceived" asp-items="ViewBag.TypeOfReceived" onchange="OnChangeTypeOfReceived()"></select>
                                        </div>
                                    </div>
                                    <div class="row">
