                        <th colspan="4">Thông tin khác</th>
                    </tr>
                    <tr>
                        <th>Ngày phát sinh</th>
                        <th>Mã phiếu</th>
                        <th>Loại phiếu</th>
                        <th>Tên đại lý</th>
                        <th>Số sim</th>
                        <th>Giá niêm yết</th>
                        <th>Giá thu về</th>
                        <th>Phí PS</th>
                        <th>P/S Tăng</th>
                        <th>P/S Giảm</th>
                        <th>Công nợ PS</th>
                        <th> Diễn giải/Ghi chú</th>
                        <th>Hình thức giao dịch</th>
                        <th>COD </th>
                        <th>Người lập</th>
