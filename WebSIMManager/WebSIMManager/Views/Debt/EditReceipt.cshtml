												<input type="text" class="form-control" asp-for="Code" readonly />
											</div>
										</div>
										<div class="form-group">
											<label class="form-label">Người lập</label>
											<div class="p-0">
												<select class="form-control" asp-for="CreateBy" asp-items="ViewBag.Staffs" type="text" data-live-search="true" style="border: 1px solid #ced4da;border-radius: .25rem;" onchange="OnChangeSupplier()" readonly>
												</select>
											</div>
										</div>
										<div class="form-group">
											<label class="form-label">Ngày lập</label>
