@model Models.Requests.GetPagingRequest
@using System.Security.Claims;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.User.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray();
    ViewData["Title"] = "Danh sách loại SIM";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Danh sách loại SIM</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="row">
                    <div class="col-sm-6 text-left">
                        @if (role.Contains("Tạo mới số đẹp"))
                        {
                            <a class="btn btn-primary" asp-action="Create" asp-controller="SIMType">Thêm số đẹp</a>
                        }
                    </div>
                    <div class="col-sm-6 text-right">
                        <form class="form-inline d-none d-sm-inline-block">
                            <div class="input-group input-group-navbar">
                                <input type="text" asp-for="keyword" class="form-control" placeholder="Số đẹp..." aria-label="Search">
                                <div class="input-group-append">
                                    <button class="btn" type="submit" asp-action="Index" asp-controller="SIMType">
                                        <i class="align-middle" data-feather="search"></i>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-3">
            <div class="table-responsive">
                <table class="table table-striped table-hover align-middle" style="table-layout: fixed; width: 100%;">
                    <thead>
                        <tr>
                            <th style="width:10%;">Tên</th>
                            <th style="width:35%">Format</th>
                            <th style="width:10%">Giá tham khảo</th>
                            <th class="d-none d-md-table-cell" style="width:35%">Mô tả</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            if (@ViewBag.DataView != null)
                                foreach (var item in @ViewBag.DataView)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Format</td>
                                        <td>@item.EstimatedPrice.ToString("#,##0.##")</td>
                                        <td class="d-none d-md-table-cell">@item.Description</td>
                                        <td class="table-action">

                                            @if (role.Contains("Sửa số đẹp"))
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Id" title="Sửa số đẹp"><i class="align-middle" data-feather="edit-2"></i></a>
                                            }
                                            @if (role.Contains("Xóa số đẹp"))
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id" title="Xóa số đẹp"><i class="align-middle" data-feather="trash"></i></a>
                                            }
                                        </td>
                                    </tr>
                                }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div id="paging" class="px-3">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-md">
                    @if (ViewBag.Pager.TotalPages > 0)
                    {
                        @if (ViewBag.Pager.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-pageIndex="1"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">
                                    Trang đầu
                                </a>
                            </li>
                        }
                        @for (var pge = ViewBag.Pager.StartPage; pge <= ViewBag.Pager.EndPage; pge++)
                        {
                            <li class="page-item @(pge == ViewBag.Pager.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-pageIndex="@pge"
                                   asp-route-pageIndex="@ViewBag.Pager.TotalPages"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">@pge</a>
                            </li>
                        }
                        @if (ViewBag.Pager.CurrentPage < ViewBag.Pager.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-pageIndex="@ViewBag.Pager.TotalPages"
                                   asp-route-keyword="@ViewBag.Pager.Key.keyword">
                                    Trang cuối
                                </a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#SIMCollapse').removeClass("collapsed");
        $('#sim').addClass("show");
        $('#SIMType').addClass("active");
    });
</script>