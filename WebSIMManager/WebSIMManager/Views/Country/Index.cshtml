@using System.Security.Claims;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.User.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray();
    ViewData["Title"] = "Quản lý Quốc gia";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="row">
                    <div class="col-sm-6 text-left">
                        @if (role.Contains("Tạo mới quốc gia"))
                        {
                            <a class="btn btn-primary" asp-action="Create" asp-controller="Country">Thêm quốc gia</a>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-3">
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th style="width:5%">STT</th>
                        <th style="width:20%">Tên quốc gia</th>
                        <th style="width:30%">Ghi chú</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var idx = 0;
                        foreach (var item in @ViewBag.DataView)
                        {
                            idx++;
                            <tr>
                                <td>@idx</td>
                                <td>@item.Name</td>
                                <td>@item.Note</td>
                                <td class="table-action">
                                    @if (role.Contains("Sửa quốc gia"))
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" title="Sửa quốc gia"><i class="align-middle" data-feather="edit-2"></i></a>
                                    }
                                    @if (role.Contains("Xóa quốc gia"))
                                    {
                                        <a asp-action="Delete" asp-route-id="@item.Id" title="Xóa quốc gia"><i class="align-middle" data-feather="trash"></i></a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#SettingsCollapse').removeClass("collapsed");
        $('#settings').addClass("show");
        $('#countryLst').addClass("active");
    });
</script>

