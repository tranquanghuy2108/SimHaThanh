@using Models.ViewModels
@model CountryModels
@{
    ViewData["Title"] = "Thêm mới quốc gia";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Thêm mới quốc gia</h1>

<div class="col-12">
    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="form-group col-md-6">
                    <label class="form-label required">Tên quốc gia</label>
                    <input type="text" class="form-control" placeholder="" asp-for="Name">
                </div>
                <div class="form-group col-md-6">
                    <label class="form-label">Ghi chú</label>
                    <textarea class="form-control" rows="2" placeholder="" asp-for="Note"></textarea>
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
                <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Create" asp-controller="Country" width="100px">Thêm mới</button>
                <button type="submit" class="btn btn-secondary m-3 btn-default" asp-action="Index" asp-controller="Country" width="100px">Trở về</button>
            </form>
        </div>
    </div>
</div>


<script>
    $(function () {
        $('#SettingsCollapse').removeClass("collapsed");
        $('#settings').addClass("show");
        $('#countryLst').addClass("active");
    });
</script>