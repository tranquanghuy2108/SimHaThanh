                    console.error("Lỗi:", jqXHR.status, jqXHR.responseText);
                    if (jqXHR.status === 401) {
                        alert("Bạn chưa đăng nhập hoặc phiên đăng nhập đã hết hạn.");
                    } else if (jqXHR.status === 403) {
                        alert("Bạn không có quyền truy cập chức năng này.");
                    } else {
                        alert("Có lỗi xảy ra khi gọi API.");
                    }
                }
            });
        }
    }
    function OnClickCheckAll() {
        var chkVal = document.getElementById('checkAll');
        if (chkVal.checked === true) {
            lstOrder = [];
            $('tr td input').each(function () {
                var orderId = parseInt($(this).val());
                lstOrder.push(orderId);
                document.getElementById(orderId).checked = true;
            })
        } else {
            $('tr td input').each(function () {
                var orderId = parseInt($(this).val());
                document.getElementById(orderId).checked = false;
            })
            lstOrder = [];
        }
    }
    function OnClickCheckBox(orderId) {
        var chkVal = document.getElementById(orderId);
        if (chkVal.checked === true) {
            lstOrder.push(orderId);
        } else {
            const index = lstOrder.indexOf(orderId);
            if (index > -1) {
                lstOrder.splice(index, 1);
            }
        }
    }
    function OnClickXuatSim(orderId) {
        if (orderId == 0) {
            if (lstOrder.length > 0) {
                var dataReq = {
                    "ids": lstOrder
                }
                $.ajax({
                    url: '@Url.Action("CheckListOrderIsOneAgent", "SIMOrder")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(dataReq),
                    success: function (resp) {
                        if (resp.data) {
                            $.ajax({
                                url: '@Url.Action("CheckListOrderIsAvalible", "SIMOrder")',
                                type: "POST",
                                contentType: "application/json",
                                data: JSON.stringify(dataReq),
                                success: function (resp2) {
                                    if (resp2.code == '1') {
                                        window.location.href = '@Url.Action("XuatSim", "SIMOrder")' + '?orderIds=' + resp2.data;
                                    } else {
                                        alert(resp2.message)
                                    }
                                },
                                error: function (xhr) {
                                    console.log(xhr);
                                }
                            });
                        } else {
                            alert('Bạn cần chọn cùng 1 KH/Đại lý mua sim.')
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr);
                    }
                });
            } else {
                alert('Bạn chưa chọn item');
            }
        }
        else {
            var orderIdsArr = [];
            orderIdsArr.push(orderId);
            var req = { "ids": orderIdsArr };
            $.ajax({
                url: '@Url.Action("CheckListOrderIsAvalible", "SIMOrder")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(req),
                success: function (resp2) {
                    if (resp2.code == '1') {
                        window.location.href = '@Url.Action("XuatSim", "SIMOrder")' + '?orderIds=' + resp2.data;
                    } else {
                        alert(resp2.message)
                    }
                },
                error: function (xhr) {
                    console.log(xhr);
                }
            });
        }
    }
    function OnClickCancel(orderId) {
        if (orderId == 0) {
            if (lstOrder.length > 0) {
                var dataReq = {
                    "ids": lstOrder
                }
                $.ajax({
                    url: '@Url.Action("CheckListOrderIsOneAgent", "SIMOrder")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(dataReq),
                    success: function (resp) {
                        if (resp.data) {
                            var req = {
                                "orderIds": lstOrder.join(","),
                                "status": 2
                            }
                            $.ajax({
                                url: '@Url.Action("OnApprovedOrder", "SIMOrder")',
                                type: "POST",
                                contentType: "application/json",
                                data: JSON.stringify(req),
                                success: function (resp2) {
                                    alert(resp2.message)
                                    if (resp2.code == '1') {
                                        window.location.href = '@Url.Action("AskSim", "SIMOrder")';
                                    }
                                },
                                error: function (xhr) {
                                    console.log(xhr);
                                }
                            });
                        } else {
                            alert('Bạn cần chọn cùng 1 KH/Đại lý mua sim')
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr);
                    }
                });
            } else {
                alert('Bạn chưa chọn item');
            }
        }
        else {
            var req = {
                "orderIds": orderId.toString(),
                "status": 2
            }
            $.ajax({
                url: '@Url.Action("OnApprovedOrder", "SIMOrder")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(req),
                success: function (resp2) {
                    alert(resp2.message)
                    if (resp2.code == '1') {
                        window.location.href = '@Url.Action("AskSim", "SIMOrder")';
                    }
                },
                error: function (xhr) {
                    console.log(xhr);
                }
            });
        }
    }
    function OnChangeDiscount() {
        var PriceOfSim = document.getElementById('PriceOfSim');
        var Discount = document.getElementById('Discount');
        var PriceOrder = document.getElementById('PriceOrder');
        var priceorder = parseFloat(PriceOfSim.value.replaceAll(",", "")) - parseFloat(PriceOfSim.value.replaceAll(",", "")) * parseFloat(Discount.value.replaceAll(",", "")) / 100;
        PriceOrder.value = priceorder;
        fomatCurrencyInput();
    }
    function OnChosseSim(id) {
        var chkVal = document.getElementById('sim_' + id);
        if (chkVal.checked === true) {
            document.getElementById('simIds').value = id;

            $('tr td input').each(function (el) {
                $(this).prop('checked', false);
            })
            document.getElementById('sim_' + id).checked = true;
            //Lấy thông tin sim được chọn
            Onloading();
            var simids = $('#simIds').val();
            var request = { "customerId": "", "simids": simids };
            $.ajax({
                url: '@Url.Action("GetSimInfoByIds", "SIMOrder")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(request),
                success: function (resp) {
                    OnloadingSuccess();
                    if (resp.simInfos.length > 0 || resp.orderInfos.length > 0) {
                        if (resp.simInfos.length > 0) {
                            var simsInOrderHtml = '<div class="sim-in-order-item mb-2">'
                            + '<input type="hidden" id="simId_' + id + '" name="simInOrders[0].simId" value="' + id + '" />'
                            + '<input type="hidden" id="simPrice_' + id + '" name="simInOrders[0].simPrice" value="' + resp.simInfos[0].price + '" />'
                            + '<input type="hidden" id="usingEsim_' + id + '" name="simInOrders[0].usingEsim" value="false" />'
                            + '</div>';
                            var simsInOrder = $('#simsInOrder');
                            simsInOrder.children().remove();
                            simsInOrder.append(simsInOrderHtml);

                            document.getElementById('retailPrice').value = resp.simInfos[0].price;
                            document.getElementById('agentPrice').value = resp.simInfos[0].agentSIMPrice;
                            document.getElementById('collaboratorsPrice').value = resp.simInfos[0].collaboratorsSIMPrice;
                            OnChangeTypePrice();
                            OnChangeAgent();
                            fomatCurrencyInput();
                        }
                    }
                },
                error: function (xhr) {
                    console.log(xhr);
                }
            });
        } else {
            document.getElementById('simIds').value = '';
        }
    }
    function OnChangeTypePrice() {
        var priceType = document.getElementById("TypePriceSimOrder").value;
        switch (priceType) {
            case "Defaul":
                document.getElementById('PriceOfSim').value = parseFloat(document.getElementById('retailPrice').value.replaceAll(",", ""));
                break;
            case "ForAgent":
                document.getElementById('PriceOfSim').value = parseFloat(document.getElementById('agentPrice').value.replaceAll(",", ""));
                break;
            case "ForCollaborators":
                document.getElementById('PriceOfSim').value = parseFloat(document.getElementById('collaboratorsPrice').value.replaceAll(",", ""));
                break;
        }
        OnChangeDiscount();
        fomatCurrencyInput();
    }
    function GetDiscountOfUser() {
        Onloading();
        var customer = $('#UserBuyId').val();
        var price = parseFloat(document.getElementById('PriceOfSim').value.replaceAll(",", ""));
        var request = { "agentId": customer, "price": price };
        $.ajax({
            url: '@Url.Action("GetDiscountOfUser", "SIMOrder")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(request),
            success: function (data) {
                OnloadingSuccess();
                document.getElementById('Discount').value = data.discount;
                OnChangeDiscount();
                fomatCurrencyInput();
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    };

</script>