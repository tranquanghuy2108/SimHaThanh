@using Commons.Enums;
@model Models.Requests.GetPagingRequest
@using System.Security.Claims;
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@{
    var role = HttpContextAccessor.HttpContext?.User.FindAll(ClaimTypes.Role).Select(x => x.Value).ToArray();
    ViewData["Title"] = "Danh sách phiếu xuất sim";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
  /* .table-container {
        overflow-x: auto;
        min-width: 1400px;
        margin: 0 20px;
        padding: 1em 0;
    }

    table {
        border-collapse: collapse;
        width: auto;
    }

        th:first-child, td:first-child {
            position: sticky;
            left: 0;
            background-color: #f2f2f2;
            z-index: 1;
        }

        th:last-child, td:last-child {
            position: sticky;
            right: 0;
            background-color: #f2f2f2;
            z-index: 1;
        } */

</style>
<input id="uRoles" type="hidden" value="@string.Join(", ", role)" />
<h1>Danh sách phiếu xuất sim</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="form-group col-12 row">
                    <div class="col-2">
                        <label class="form-label">KH/Đại lý</label>
                        <div class="col-12 p-0">
                            <select id="agentIds" type="text" asp-items="@ViewBag.Agents" multiple="multiple" data-live-search="true">
                            </select>
                        </div>
                    </div>
                    <div class="col-2">
                        <label class="form-label">Số sim</label>
                        <div class="col-12 p-0">
                            <input id="simNumber" type="text" class="form-control" placeholder="Nhập số sim..." />
                        </div>
                    </div>
                    <div class="col-2">
                        <label class="form-label">Mã phiếu xsim</label>
                        <div class="col-12 p-0">
                            <input id="code" type="text" class="form-control" placeholder="Nhập số sim..." />
                        </div>
                    </div>
                    <div class="col-2">
                        <label class="form-label">Người tạo</label>
                        <div class="col-12 p-0">
                            <select id="staffIds" type="text" asp-items="@ViewBag.Staff" multiple="multiple" data-live-search="true">
                            </select>
                        </div>
                    </div>
                    <div class="col-2">
                        <label class="form-label">Trạng thái</label>
                        <div class="col-12 p-0">
                            <select id="status" type="text" asp-items="@ViewBag.Status" data-live-search="true">
                                <option value="0">Tất cả</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <button class="btn btn-primary" onclick="filter(1)">Tìm kiếm</button>
                    <button class="btn btn-warning mx-4" onclick="exportReport()">Xuất Excel</button>
                </div>
            </div>

            <div class="card p-3">
                <div class="col-12 rows">
                    @if (role.Contains("Duyệt công nợ"))
                    {
                        <a class="btn btn-primary" onclick="OnClickApprovedPXS(2,0);">Duyệt phiếu</a>
                        <a class="btn btn-danger mx-4" onclick="OnClickApprovedPXS(3,0);">Hủy phiếu</a>
                    }
                </div>
            </div>
        </div>

        <div class="card-body table-container" style="overflow-x: scroll;">
            <table id="myTable" class="table table-bordered table-striped" style="width: 150%;">
                <thead>
                    <tr>
                        <th colspan="3"></th>
                        <th colspan="8">Thông phiếu xuất</th>
                        <th colspan="8">Thông tin mua hàng</th>
                        <th colspan="4">Thông tin khác</th>
                    </tr>
                    <tr>
                        <th>
                            <input type="checkbox" value="" id="checkAll" onclick="OnClickCheckAll()">
                            <input type="hidden" id="lstOrder">
                        </th>
                        <th>Thao tác</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo phiếu</th>
                        <th>Ngày lập phiếu</th>
                        <th>Mã phiếu</th>
                        <th>Số sim</th>
                        <th>Tổng đơn hàng</th>
                        <th>Tổng đã TT</th>
                        <th>Còn lại chưa TT</th>
                        <th>Ghi chú</th>
                        <th>Tên khách hàng</th>
                        <th>Phí cộng trừ bên mua</th>
                        <th>Tên ĐV GD hộ</th>
                        <th>Tiền thu hộ/COD</th>
                        <th>Phí</th>
                        <th>Hình thức giao dịch</th>
                        <th>Số ĐT khách hàng</th>
                        <th>Địa chỉ khách hàng</th>
                        <th>Người bán</th>
                        <th>Người lập</th>
                        <th>Trạng thái vận chuyển</th>
                        <th>Đã thu COD</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
        <div id="paging" class="px-3">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-md">
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#OrderCollapse').removeClass("collapsed");
        $('#order').addClass("show");
        $('#phieuXuatSim').addClass("active");
    });
</script>
<script type="text/javascript">
    window.onload = filter(1);
    var lstOrder = [];
    function filter(page) {
        var simNumber = $('#simNumber').val();
        var code = $('#code').val();
        var agent = $('#agentIds').val();
        var staff = $('#staffIds').val();
        var status = $('#status').val();
        var data = { "debtPrefix": "PXSCN", "simNumber": simNumber, "code": code, "codCode": "", "apprStatus": parseInt(status), "staffIds": staff, "agentIds": agent, "pageIndex": page, "pageSize": 20 };
        $.ajax({
            url: '@Url.Action("SearchPhieuXuatSim","SIMOrder")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            success: function (data) {
                //Write table tbody
                var tbody = $("#myTable tbody")
                tbody.children().remove();
                var newBody = "";
                data.data.forEach((el) => {
                    var action = '';
                    var role = $('#uRoles').val();
                    action += '<a class="m-1" href="@Url.Action("EditXuatSim","SIMOrder")?debtId=' + el.id + '" title="Chi tiết phiếu"><i class="fa fa-edit"></i></a>';
                    if (role.includes("Duyệt công nợ")) {
                        action += '<a class="m-1" onclick="OnClickApprovedPXS(2,' + el.id + ');" title="Approved phiếu"><i class="fa fa-check"></i></a>';
                        action += '<a class="m-1" onclick="OnClickApprovedPXS(3,' + el.id + ');" title="Hủy phiếu"><i class="fa fa-times"></i></a>';
                    }
                    if (role.includes("Xóa phiếu xuất sim")) {
                        action += '<a class="m-1" onclick="OnClickDelete(' + el.id + ');" title="Xóa PXSim"><i class="fa fa-trash"></i></a>';
                    }
                    newBody += '<tr>'
                        + '<td><input type="checkbox" value="' + el.id + '" id="' + el.id + '" onclick="OnClickCheckBox(' + el.id + ')"></td>'
                        + '<td class="table-action" >'
                        + action
                        + '</td>'
                        + '<td>' + el.approvedStatusStr + '</td>'
                        + '<td>' + el.createTime + '</td>'
                        + '<td>' + el.deliveryDate + '</td>'
                        + '<td><a class="m-1" href="@Url.Action("EditXuatSim","SIMOrder")?debtId=' + el.id + '" title="Chi tiết phiếu">' + (el.code ? el.code : '') + '</a></td>'
                        + '<td>' + (el.listSimNumberInOrder ? el.listSimNumberInOrder : '') + '</td>'
                        + '<td>' + formatCurrency(el.orderPrice) + '</td>'
                        + '<td>' + formatCurrency(el.tienDaThu) + '</td>'
                        + '<td>' + formatCurrency(el.phaiThuConLai) + '</td>'
                        + '<td>' + (el.note ? el.note : '') + '</td>'
                        + '<td>' + (el.customerName ? el.customerName : '') + '</td>'
                        + '<td>' + formatCurrency(el.otherFee) + '</td>'
                        + '<td>' + (el.shippingName ? el.shippingName : '') + '</td>'
                        + '<td>' + formatCurrency(el.cod) + '</td>'
                        + '<td>' + formatCurrency(el.shippingFee) + '</td>'
                        + '<td>' + (el.formOfDeliveryId ? el.formOfDeliveryId : '') + '</td>'
                        + '<td>' + (el.customerPhone ? el.customerPhone : '') + '</td>'
                        + '<td>' + (el.customerAddress ? el.customerAddress : '') + '</td>'
                        + '<td>' + (el.createBy ? el.createBy : '') + '</td>'
                        + '<td>' + (el.approvedBy ? el.approvedBy : '') + '</td>'
                        + '<td>' + (el.flagCOD ? el.flagCOD : '') + '</td>'
                        + '<td>' + (el.flagThuHo ? el.flagThuHo : '') + '</td>'
                        + '</tr>';
                });
                tbody.append(newBody);
                //write paging
                console.log(data.pager);
                var paging = $("#paging .pagination")
                paging.children().remove();
                var pagingItem = "";
                if (data.pager.totalPages > 0) {
                    if (data.pager.currentPage > 1) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filter(1)" >Trang đầu</a></li>'
                    };
                    for (var pge = data.pager.startPage; pge <= data.pager.endPage; pge++) {
                        if (pge == data.pager.currentPage)
                            pagingItem += '<li class="page-item active"><a class="page-link" onclick="filter(' + pge + ')" >' + pge + '</a></li>'
                        else
                            pagingItem += '<li class="page-item "><a class="page-link" onclick="filter(' + pge + ')" >' + pge + '</a></li>'
                    }
                    if (data.pager.currentPage < data.pager.totalPages) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filter(' + data.pager.totalPages + ')" >Trang cuối</a></li>'
                    };
                }
                paging.append(pagingItem);
            },
            error: function (xhr) {
                console.log(xhr);
            }
        });
    };

    function OnClickCheckAll() {
        var chkVal = document.getElementById('checkAll');
        if (chkVal.checked === true) {
            console.log("Checkbox is checked - boolean value: ", chkVal.checked);
            lstOrder = [];
            $('tr td input').each(function () {
                var orderId = parseInt($(this).val());
                lstOrder.push(orderId);
                document.getElementById(orderId).checked = true;
            })
            console.log('result ' + lstOrder);
        } else {
            console.log("Checkbox is checked - boolean value: ", chkVal.checked);
            $('tr td input').each(function () {
                var orderId = parseInt($(this).val());
                document.getElementById(orderId).checked = false;
            })
            lstOrder = [];
            console.log('result ' + lstOrder);
        }
    }
    function OnClickCheckBox(orderId) {
        var chkVal = document.getElementById(orderId);
        if (chkVal.checked === true) {
            console.log("Checkbox is checked - boolean value: ", chkVal.checked);
            lstOrder.push(orderId);
            console.log('result ' + lstOrder);
        } else {
            console.log("Checkbox is checked - boolean value: ", chkVal.checked);
            const index = lstOrder.indexOf(orderId);
            if (index > -1) {
                lstOrder.splice(index, 1);
            }
            console.log('result ' + lstOrder);
        }
    }
    function OnClickApprovedPXS(status, debtId) {
        if (debtId == 0) {
            if (lstOrder.length > 0) {
                var dataReq = {
                    "debtIds": lstOrder.join(','),
                    "status": status
                }
                $.ajax({
                    url: '@Url.Action("OnApprovedPXS","SIMOrder")',
                    type: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(dataReq),
                    success: function (data) {
                        alert(data.message)
                        if (data.code == "1") {
                            window.location.href = '@Url.Action("PhieuXuatSim","SIMOrder")';
                        }
                    },
                    error: function (xhr) {
                        console.log(xhr);
                    }
                });
            } else {
                alert('Bạn chưa chọn item');
            }
        }
        else {
            var dataReq = {
                "debtIds": debtId.toString(),
                "status": status
            }
            $.ajax({
                url: '@Url.Action("OnApprovedPXS","SIMOrder")',
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify(dataReq),
                success: function (data) {
                    alert(data.message)
                    if (data.code == "1") {
                        window.location.href = '@Url.Action("PhieuXuatSim","SIMOrder")';
                    }
                },
                error: function (xhr) {
                    console.log(xhr);
                }
            });
        }
    }

    function exportReport() {
        Onloading();
        var agent = $('#agentIds').val();
        var staff = $('#staffIds').val();
        var status = $('#status').val();
        var data = { "debtPrefix": "PXSCN", "apprStatus": parseInt(status), "staffIds": staff, "agentIds": agent, "pageIndex": 1, "pageSize": 2147483647 };
        $.ajax({
            url: '@Url.Action("ExportPhieuXuatSim", "SIMOrder")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            xhrFields: {
                responseType: 'blob'
            },
            success: function (data) {
                OnloadingSuccess();
                var a = document.createElement('a');
                var url = window.URL.createObjectURL(data);
                a.href = url;
                a.download = 'bao cao sim da ban.xlsx';
                document.body.append(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);
            },
            error: function (xhr, status, error) {
                console.error(error);
            }
        });
    };
    function OnClickDelete(id) {
        if (confirm("Bạn có chắc chắn xóa!") == true) {
            $.ajax({
                url: '@Url.Action("DeletePXS","SIMOrder")?id=' + id + '',
                type: "GET",
                contentType: "application/json",
                success: function (data) {
                    alert(data.message)
                    if (data.code == "1") {
                        window.location.href = '@Url.Action("PhieuXuatSim","SIMOrder")';
                    }
                },
                error: function (xhr) {
                    alert('Có lỗi trong quá trình xóa dữ liệu')
                    console.log(xhr);
                }
            });
        }
    }
</script>