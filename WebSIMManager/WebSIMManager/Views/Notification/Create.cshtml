@using Models.ViewModels
@model NotificationModel
@{
    ViewData["Title"] = "Thêm thông báo";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Thêm thông báo</h1>

<div class="col-12">
    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="form-group col-md-6">
                    <label class="form-label required">Tiêu đề</label>
                    <input type="text" class="form-control" placeholder="" asp-for="Title">
                    <input type="hidden" asp-for="CollaboratorsGroupId" value="0" />
                </div>

                <div class="form-group col-md-6">
                    <label class="form-label">Nội dung</label>
                    <textarea class="form-control" rows="5" placeholder="" asp-for="Content"></textarea>
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
                <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Create" asp-controller="Notification" width="100px">Thêm mới</button>
                <button type="submit" class="btn btn-secondary m-3 btn-default" asp-action="Index" asp-controller="Notification" width="100px">Trở về</button>
            </form>
        </div>
    </div>
</div>


<script>
    $(function () {
        $('#AppManagerCollapse').removeClass("collapsed");
        $('#appManager').addClass("show");
        $('#notifications').addClass("active");
    });
</script>