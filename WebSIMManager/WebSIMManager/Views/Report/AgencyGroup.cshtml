@{
    ViewData["Title"] = "Báo cáo nhóm đại lý";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Báo cáo nhóm đại lý</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="form-group col-12 row">
                    <div class="col-3">
                        <label class="form-label">Tìm kiếm</label>
                        <input id="keyword" type="text" class="form-control" placeholder="Nhập tên đại lý">
                    </div>
                    <div class="col-3">
                        <label class="form-label">Từ ngày</label>
                        <div class="col-12 p-0">
                            <input id="startDate" type="date" class="form-control" placeholder="Nhập ngày bắt đầu" />
                        </div>
                    </div>
                    <div class="col-3">
                        <label class="form-label">Đến ngày</label>
                        <div class="col-12 p-0">
                            <input id="endDate" type="date" class="form-control" placeholder="Nhập ngày kết thúc" />
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <button class="btn btn-primary" onclick="filterReport(1)">Tìm kiếm</button>
                    <button class="btn btn-warning mx-4" onclick="exportReport()">Xuất Excel</button>
                </div>
            </div>
        </div>

        <div class="card-body px-3">
            <table id="myTable" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th style="width:5%">Stt</th>
                        <th style="width:20%">Tên đại lý</th>
                        <th style="width:10%">Điện thoại</th>
                        <th style="width:25%">Địa chỉ</th>
                        <th style="width:10%">Phải thu</th>
                        <th style="width:10%">Phải trả</th>
                        <th style="width:10%">Nợ cuối</th>
                        <th style="width:10%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
        <div id="paging" class="px-3">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-md">
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#DebtCollapse').removeClass("collapsed");
        $('#debt').addClass("show");
        $('#AgencyGroup').addClass("active");
    });
</script>

<script type="text/javascript">
    window.onload = filterReport(1);
    var lstOrder = [];
    function filterReport(page) {
        Onloading();
        var keyword = $('#keyword').val();
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        if (startDate === '') {
            startDate = null;
        }
        if (endDate === '') {
            endDate = null;
        }
        var data = { "isPaged": true, "pageIndex": page, "pageSize": 50, "keyword": keyword, "startDate": startDate, "endDate": endDate };
        $.ajax({
            url: '@Url.Action("SearchAgencyGroup", "Report")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            success: function (data) {
                OnloadingSuccess();
                //Write table tbody
                var tbody = $("#myTable tbody")
                tbody.children().remove();
                var newBody = "";

                console.log(data.data);
                data.data.forEach((el) => {
                    var url = '@Url.Action("CustomerDebt", "Report")' + '?userId=' + el.agentId;
                    var urlReceipt = '@Url.Action("CreateReceipt", "Debt")' + '?agentId=' + el.agentId;
                    if (startDate) {
                        url += '&startDate=' + startDate;
                    }
                    if (endDate) {
                        url += '&endDate=' + endDate;
                    }
                    newBody += '<tr>'
                        + '<td>' + el.stt + '</td>'
                        + '<td>' + el.fullName + '</td>'
                        + '<td>' + (el.phoneNumber ? el.phoneNumber : '') + '</td>'
                        + '<td>' + (el.address ? el.address : '') + '</td>'
                        + '<td>' + formatCurrency(el.totalReceivables) + '</td>'
                        + '<td>' + formatCurrency(el.totalLiabilities) + '</td>'
                        + '<td>' + formatCurrency(el.totalFinalDebt) + '</td>'
                        + '<td>'
                        + '<a class="m-1" href="' + url + '" title="Chi tiết"><i class="fa fa-eye"></i></a>'
                        + '<a class="m-1" href="' + urlReceipt + '" title="Tạo phiếu thu/chi"><i class="fas fa-receipt"></i></a>'
                        + '</td>'
                        + '</tr>';
                });
                tbody.append(newBody);

                console.log(data.pager);
                var paging = $("#paging .pagination")
                paging.children().remove();
                var pagingItem = "";
                if (data.pager.totalPages > 0) {
                    if (data.pager.currentPage > 1) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filterReport(1)" >Trang đầu</a></li>'
                    };
                    for (var pge = data.pager.startPage; pge <= data.pager.endPage; pge++) {
                        if (pge == data.pager.currentPage)
                            pagingItem += '<li class="page-item active"><a class="page-link" onclick="filterReport(' + pge + ')" >' + pge + '</a></li>'
                        else
                            pagingItem += '<li class="page-item "><a class="page-link" onclick="filterReport(' + pge + ')" >' + pge + '</a></li>'
                    }
                    if (data.pager.currentPage < data.pager.totalPages) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filterReport(' + data.pager.totalPages + ')" >Trang cuối</a></li>'
                    };
                }
                paging.append(pagingItem);
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    };

    function exportReport() {
        Onloading();
        var keyword = $('#keyword').val();
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        if (startDate === null || startDate === '') {
            startDate = '1900-01-01';
        }
        if (endDate === null || endDate === '') {
            endDate = '2999-12-31';
        }
        var data = { "isPaged": false, "pageIndex": 1, "pageSize": 50, "keyword": keyword, "startDate": startDate, "endDate": endDate };
        $.ajax({
            url: '@Url.Action("ExportAgencyGroup", "Report")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            xhrFields: {
                responseType: 'blob'
            },
            success: function (data) {
                OnloadingSuccess();
                var a = document.createElement('a');
                var url = window.URL.createObjectURL(data);
                a.href = url;
                a.download = 'bao cao nhom dai ly.xlsx';
                document.body.append(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);
            },
            error: function (xhr, status, error) {
                console.error(error);
            }
        });
    }
</script>