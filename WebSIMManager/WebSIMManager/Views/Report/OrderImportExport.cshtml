@{
    ViewData["Title"] = "Báo cáo đơn hàng nhập xuất";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Báo cáo đơn hàng nhập xuất</h1>
<div class="col-12">
    <div class="card">
        <div class="card-header">
            <div class="card p-3">
                <div class="form-group col-12 row">
                    <div class="col-3">
                        <label class="form-label">Loại phiếu</label>
                        <div class="col-12 p-0">
                            <select id="type" type="text" data-live-search="true" placeholder="Chọn loại phiếu">
                                <option value="0">Tất cả</option>
                                <option value="1">Phiếu nhập kho</option>
                                <option value="2">Phiếu xuất Kho</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-3">
                        <label class="form-label">Từ ngày</label>
                        <div class="col-12 p-0">
                            <input id="startDate" type="date" class="form-control" placeholder="Nhập ngày bắt đầu" />
                        </div>
                    </div>
                    <div class="col-3">
                        <label class="form-label">Đến ngày</label>
                        <div class="col-12 p-0">
                            <input id="endDate" type="date" class="form-control" placeholder="Nhập ngày kết thúc" />
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <button class="btn btn-primary" onclick="filterReport(1)">Tìm kiếm</button>
                    <button class="btn btn-warning mx-4" onclick="exportReport()">Xuất Excel</button>
                </div>
            </div>
        </div>

        <div class="card-body px-3">
            <table id="myTable" class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Ngày phát sinh</th>
                        <th>Mã phiếu</th>
                        <th>Mã</th>
                        <th>Sản phẩm</th>
                        <th>SLượng</th>
                        <th>Khách hàng</th>
                        <th>Loại phiếu</th>
                        <th>Người lập</th>
                        <th>Ngày lập</th>
                        <th>Kho</th>
                        <th>Đã duyệt</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
        <div id="paging" class="px-3">
            <nav aria-label="Page navigation example">
                <ul class="pagination pagination-md">
                </ul>
            </nav>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#ReportCollapse').removeClass("collapsed");
        $('#report').addClass("show");
        $('#OrderImportExport').addClass("active");
    });
</script>

<script type="text/javascript">
    window.onload = filterReport(1);
    var lstOrder = [];
    function filterReport(page) {
        Onloading();
        var type = $('#type').val();
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        if (type === '') {
            type = null;
        }
        if (startDate === '') {
            startDate = null;
        }
        if (endDate === '') {
            endDate = null;
        }
        var data = { "isPaged": true, "pageIndex": page, "pageSize": 50, "startDate": startDate, "endDate": endDate, "type": type };
        $.ajax({
            url: '@Url.Action("SearchOrderImportExport", "Report")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            success: function (data) {
                OnloadingSuccess();
                //Write table tbody
                var tbody = $("#myTable tbody")
                tbody.children().remove();
                var newBody = "";
                data.data.forEach((el) => {
                    var invoidCode = "";
                    if (el.invoiceCode.includes("PXK"))
                        invoidCode = '<a href="@Url.Action("EditGoodsDeliveryNote","Warehouse")?id=' + el.invoiceId + '" title="Chi tiết PXK ' + el.invoiceCode + '">' + el.invoiceCode + '</a>';
                    if (el.invoiceCode.includes("PNK"))
                        invoidCode = '<a href="@Url.Action("EditGoodsReceivedNote","Warehouse")?id=' + el.invoiceId + '" title="Chi tiết PNK ' + el.invoiceCode + '">' + el.invoiceCode + '</a>';
                    newBody += '<tr>'
                        + '<td>' + el.stt + '</td>'
                        + '<td>' + formatFullDate(new Date(el.dateOfOccurrence)) + '</td>'
                        + '<td>' + invoidCode + '</td>'
                        //+ '<td>' + (el.invoiceCode ? el.invoiceCode : '') + '</td>'
                        + '<td>' + (el.code ? el.code : '') + '</td>'
                        + '<td>' + (el.product ? el.product : '') + '</td>'
                        + '<td>' + formatCurrency(el.quantity) + '</td>'
                        + '<td>' + (el.customer ? el.customer : '') + '</td>'
                        + '<td>' + (el.invoiceType ? el.invoiceType : '') + '</td>'
                        + '<td>' + (el.creator ? el.creator : '') + '</td>'
                        + '<td>' + formatFullDate(new Date(el.dateCreated)) + '</td>'
                        + '<td>' + (el.warehouse ? el.warehouse : '') + '</td>'
                        + '<td>' + (el.approved ? el.approved : false) + '</td>'
                        + '</tr>';
                });
                tbody.append(newBody);

                console.log(data.pager);
                var paging = $("#paging .pagination")
                paging.children().remove();
                var pagingItem = "";
                if (data.pager.totalPages > 0) {
                    if (data.pager.currentPage > 1) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filterReport(1)" >Trang đầu</a></li>'
                    };
                    for (var pge = data.pager.startPage; pge <= data.pager.endPage; pge++) {
                        if (pge == data.pager.currentPage)
                            pagingItem += '<li class="page-item active"><a class="page-link" onclick="filterReport(' + pge + ')" >' + pge + '</a></li>'
                        else
                            pagingItem += '<li class="page-item "><a class="page-link" onclick="filterReport(' + pge + ')" >' + pge + '</a></li>'
                    }
                    if (data.pager.currentPage < data.pager.totalPages) {
                        pagingItem += '<li class="page-item" ><a class="page-link" onclick="filterReport(' + data.pager.totalPages + ')" >Trang cuối</a></li>'
                    };
                }
                paging.append(pagingItem);
            },
            error: function (xhr) {
                OnloadingSuccess();
                console.log(xhr);
            }
        });
    };

    function exportReport() {
        Onloading();
        var type = $('#type').val();
        var startDate = $('#startDate').val();
        var endDate = $('#endDate').val();
        if (type === '') {
            type = null;
        }
        if (startDate === '') {
            startDate = null;
        }
        if (endDate === '') {
            endDate = null;
        }
        var data = { "isPaged": false, "pageIndex": 1, "pageSize": 50, "startDate": startDate, "endDate": endDate, "type": type };
        $.ajax({
            url: '@Url.Action("ExportOrderImportExport", "Report")',
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(data),
            xhrFields: {
                responseType: 'blob'
            },
            success: function (data) {
                OnloadingSuccess();
                var a = document.createElement('a');
                var url = window.URL.createObjectURL(data);
                a.href = url;
                a.download = 'bao cao don hang nhap xuat.xlsx';
                document.body.append(a);
                a.click();
                a.remove();
                window.URL.revokeObjectURL(url);
            },
            error: function (xhr, status, error) {
                console.error(error);
            }
        });
    }

    function formatFullDate(date) {
        if (!date) return ''; // Check if date is null or undefined, then return an empty string
        const day = String(date.getDate()).padStart(2, '0');
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const year = date.getFullYear();
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        const seconds = String(date.getSeconds()).padStart(2, '0');
        return `${day}/${month}/${year} ${hours}:${minutes}:${seconds}`;
    }
</script>