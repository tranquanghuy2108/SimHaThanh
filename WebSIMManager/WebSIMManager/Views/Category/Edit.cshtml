@using Models.ViewModels
@model CategoryEditModel
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1>Cập nhật danh mục</h1>

<div class="col-12">
    <div class="card">
        <div class="card-body">
            <form method="post">
                <div class="form-group col-md-6">
                    <label class="form-label required">Tên danh mục</label>
                    <input type="text" class="form-control" placeholder="" asp-for="Name">
                    @Html.HiddenFor(model =>model.Id)
                </div>
                <div class="form-group col-md-6">
                    <label class="form-label required">Tên danh mục cha</label>
                    <select type="text" class="form-control" placeholder="" asp-for="ParentId" asp-items="@ViewBag.Category"></select>
                </div>
                <div class="form-group col-md-6">
                    <label class="form-label required">Tóm tắt</label>
                    <input type="text" class="form-control" placeholder="" asp-for="Summary">
                </div>
                <div class="form-group col-md-6">
                    <label class="form-label required">Đường dẫn</label>
                    <input type="text" class="form-control" placeholder="" asp-for="Url">
                </div>
                <div asp-validation-summary="All" class="text-danger"></div>
                <button type="submit" class="btn btn-primary m-3 btn-default" asp-action="Edit" asp-controller="Category" width="100px">Cập nhật</button>
                <button type="submit" class="btn btn-secondary m-3 btn-default" asp-action="Index" asp-controller="Category" width="100px">Trở về</button>
            </form>
        </div>
    </div>
</div>

<script>
    $(function () {
        $('#NewsCollapse').removeClass("collapsed");
        $('#news').addClass("show");
        $('#catagory').addClass("active");
    });
</script>